{
    "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
    "vcs": {
        "enabled": false,
        "clientKind": "git",
        "useIgnoreFile": false
    },
    "files": {
        "ignoreUnknown": false,
        "includes": [
            "**/src/**/*",
            "**/.vscode/**/*",
            "**/index.html",
            "**/vite.config.ts",
            "!**/src/routeTree.gen.ts",
            "!**/src/styles.css"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 90
    },
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "javascript": {
        "formatter": {
            "quoteStyle": "double"
        }
    }
}
